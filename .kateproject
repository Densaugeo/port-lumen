{
  "lspclient": {
    "servers": {
      "python": {
        "command": [
          "sudo", "-u", "agents",
          "apptainer", "exec", "--containall",
            "--bind", "%{Project:NativePath}:%{Project:NativePath}:rw",
            "--cwd", "%{Project:NativePath}",
            "%{Project:NativePath}/apptainers/test.sif",
          "pylsp"
        ],
        "root": "%{Project:NativePath}",
        "highlightingModeRegex": "^Python$"
      }
    }
  }
}
